{
  "_comment": "Online Boutique topology (12 services). Based on Google Cloud microservices-demo architecture. frontend calls most services; checkoutservice orchestrates purchase flow.",
  "diagram": {
    "uri": "arch://online-boutique/latest",
    "name": "online-boutique-topology",
    "description": "Google Cloud Online Boutique — 12-service e-commerce demo used in RCAEval RE2-OB benchmark.",
    "mimeType": "application/json",
    "content": {
      "services": [
        "frontend",
        "cartservice",
        "productcatalogservice",
        "currencyservice",
        "paymentservice",
        "shippingservice",
        "emailservice",
        "checkoutservice",
        "recommendationservice",
        "adservice",
        "redis-cart",
        "loadgenerator"
      ],
      "edges": [
        ["frontend", "cartservice"],
        ["frontend", "productcatalogservice"],
        ["frontend", "currencyservice"],
        ["frontend", "recommendationservice"],
        ["frontend", "checkoutservice"],
        ["frontend", "adservice"],
        ["frontend", "shippingservice"],
        ["cartservice", "redis-cart"],
        ["checkoutservice", "cartservice"],
        ["checkoutservice", "productcatalogservice"],
        ["checkoutservice", "currencyservice"],
        ["checkoutservice", "paymentservice"],
        ["checkoutservice", "shippingservice"],
        ["checkoutservice", "emailservice"],
        ["recommendationservice", "productcatalogservice"]
      ]
    }
  },
  "services": {
    "frontend": {
      "type": "frontend",
      "criticality": "high",
      "depends_on": ["cartservice", "productcatalogservice", "currencyservice", "recommendationservice", "checkoutservice", "adservice", "shippingservice"],
      "upstream_of": []
    },
    "cartservice": {
      "type": "backend",
      "criticality": "high",
      "depends_on": ["redis-cart"],
      "upstream_of": ["frontend", "checkoutservice"]
    },
    "productcatalogservice": {
      "type": "backend",
      "criticality": "high",
      "depends_on": [],
      "upstream_of": ["frontend", "checkoutservice", "recommendationservice"]
    },
    "currencyservice": {
      "type": "backend",
      "criticality": "medium",
      "depends_on": [],
      "upstream_of": ["frontend", "checkoutservice"]
    },
    "paymentservice": {
      "type": "backend",
      "criticality": "high",
      "depends_on": [],
      "upstream_of": ["checkoutservice"]
    },
    "shippingservice": {
      "type": "backend",
      "criticality": "medium",
      "depends_on": [],
      "upstream_of": ["frontend", "checkoutservice"]
    },
    "emailservice": {
      "type": "backend",
      "criticality": "low",
      "depends_on": [],
      "upstream_of": ["checkoutservice"]
    },
    "checkoutservice": {
      "type": "backend",
      "criticality": "high",
      "depends_on": ["cartservice", "productcatalogservice", "currencyservice", "paymentservice", "shippingservice", "emailservice"],
      "upstream_of": ["frontend"]
    },
    "recommendationservice": {
      "type": "backend",
      "criticality": "low",
      "depends_on": ["productcatalogservice"],
      "upstream_of": ["frontend"]
    },
    "adservice": {
      "type": "backend",
      "criticality": "low",
      "depends_on": [],
      "upstream_of": ["frontend"]
    },
    "redis-cart": {
      "type": "database",
      "criticality": "high",
      "depends_on": [],
      "upstream_of": ["cartservice"]
    },
    "loadgenerator": {
      "type": "frontend",
      "criticality": "low",
      "depends_on": ["frontend"],
      "upstream_of": []
    }
  }
}
