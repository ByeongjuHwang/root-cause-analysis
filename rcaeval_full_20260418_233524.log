PS>Get-ChildItem llm_logs\*log_agent*.json |
    Where-Object { $_.LastWriteTime -gt (Get-Date).AddMinutes(-30) } |
    Sort-Object LastWriteTime -Descending |
    Select-Object -First 5 |
    ForEach-Object {
        $d = Get-Content $_.FullName -Raw | ConvertFrom-Json
        $timeRange = if ($d.user_prompt -match "Time range: (.+?) to (.+?)[\r\n]") {
            "$($matches[1].Trim()) ~ $($matches[2].Trim())"
        } else { "N/A" }
        $hasStats = $d.user_prompt -match "Service-level Log Statistics"
        [PSCustomObject]@{
            Name = $_.Name.Substring(0, [Math]::Min(50, $_.Name.Length))
            TimeRange = $timeRange
            HasStats = $hasStats
        }
    } | Format-Table -AutoSize

