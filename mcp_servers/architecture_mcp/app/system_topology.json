{
  "diagram": {
    "uri": "arch://system/latest",
    "name": "microservice-system-diagram",
    "description": "Latest architecture diagram for the thesis RCA demo system.",
    "mimeType": "application/json",
    "content": {
      "diagram_path": "data/topology/system-diagram.png",
      "services": [
        "frontend-web",
        "api-gateway",
        "auth-service",
        "catalog-service",
        "order-service",
        "worker-service",
        "message-queue",
        "user-db",
        "order-db"
      ],
      "edges": [
        [
          "frontend-web",
          "api-gateway"
        ],
        [
          "api-gateway",
          "auth-service"
        ],
        [
          "api-gateway",
          "catalog-service"
        ],
        [
          "api-gateway",
          "order-service"
        ],
        [
          "order-service",
          "message-queue"
        ],
        [
          "message-queue",
          "worker-service"
        ],
        [
          "auth-service",
          "user-db"
        ],
        [
          "order-service",
          "order-db"
        ],
        [
          "worker-service",
          "order-db"
        ]
      ]
    }
  },
  "services": {
    "frontend-web": {
      "type": "frontend",
      "criticality": "high",
      "depends_on": [
        "api-gateway"
      ],
      "upstream_of": []
    },
    "api-gateway": {
      "type": "gateway",
      "criticality": "high",
      "depends_on": [
        "auth-service",
        "catalog-service",
        "order-service"
      ],
      "upstream_of": [
        "frontend-web"
      ]
    },
    "auth-service": {
      "type": "backend",
      "criticality": "high",
      "depends_on": [
        "user-db"
      ],
      "upstream_of": [
        "api-gateway"
      ]
    },
    "catalog-service": {
      "type": "backend",
      "criticality": "medium",
      "depends_on": [],
      "upstream_of": [
        "api-gateway"
      ]
    },
    "order-service": {
      "type": "backend",
      "criticality": "high",
      "depends_on": [
        "message-queue",
        "order-db"
      ],
      "upstream_of": [
        "api-gateway"
      ]
    },
    "message-queue": {
      "type": "queue",
      "criticality": "high",
      "depends_on": [
        "worker-service"
      ],
      "upstream_of": [
        "order-service"
      ]
    },
    "worker-service": {
      "type": "worker",
      "criticality": "high",
      "depends_on": [
        "order-db"
      ],
      "upstream_of": [
        "message-queue"
      ]
    },
    "user-db": {
      "type": "database",
      "criticality": "high",
      "depends_on": [],
      "upstream_of": [
        "auth-service"
      ]
    },
    "order-db": {
      "type": "database",
      "criticality": "high",
      "depends_on": [],
      "upstream_of": [
        "order-service",
        "worker-service"
      ]
    }
  }
}